# ── Rust / Cargo ──────────────────────────────────────
/target/
**/*.rs.bk
Cargo.lock.bak

# ── C++ build artifacts ──────────────────────────────
cpp/build/
cpp/out/
*.o
*.obj
*.so
*.dylib
*.dll
*.a
*.lib
*.exp
*.pdb

# ── Dev-generated content (resources/) ───────────────
# Compiled scripts (keep source .cpp/.h, ignore built libs)
resources/scripts/*.so
resources/scripts/*.dylib
resources/scripts/*.dll
# Saved maps, exported data
resources/**/*.tmap
resources/**/*.json
resources/**/*.bin
# Let devs opt-in to tracking specific content via git add -f

# ── IDE / Editor ─────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.kate-swp
.project
.classpath
.settings/

# ── OS files ─────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
._*

# ── Trunk / WebGL ────────────────────────────────────
dist/

# ── Misc ─────────────────────────────────────────────
*.log
*.bak
*.tmp
